datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 1. USER MANAGEMENT & AUTHENTICATION MODULE
// ==========================================
model User {
  id            Int                  @id @default(autoincrement())
  name          String
  email         String               @unique
  password      String               
  phoneNumber   String               @db.VarChar(20)
  role          Role                 @default(BIDDER)
  isVerified    Boolean              @default(false) 
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  // Relations
  bids          Bid[]
  payments      Payment[]
  assets        Asset[]              
  registrations AuctionRegistration[]

  @@map("users") 
}

enum Role {
  BIDDER
  AUCTIONEER
  ADMIN
}

// ==========================================
// 2. UNIVERSAL DYNAMIC ASSET MODULE (FULLY FLEXIBLE)
// ==========================================
model Asset {
  id            Int           @id @default(autoincrement())
  title         String        @db.VarChar(255) 
  description   String        @db.Text
  location      String        @db.VarChar(255) 
  
  // Stored as a plain String so auctioneers can type "VEHICLE", "REAL_ESTATE", or any custom category name
  category      String        @db.VarChar(100) @default("OTHER")
  
  // DYNAMIC COMPLIANCE BLOCK - INFINITE KEY/VALUE GENERATION
  // Stores any custom attributes appended by the user via the dashboard plus button
  // e.g., {"Mileage": "4500k", "Engine": "V8"} or {"Bedrooms": 3} or {"RAM": "16GB"}
  attributes    Json          

  // Legal & Ownership Documentation (Logbooks, Deeds, Receipts)
  documentUrl   String?       @db.Text 
  
  createdById   Int
  createdBy     User          @relation(fields: [createdById], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  auctionItems  AuctionItem[]

  @@map("assets")
}

// ==========================================
// 3. AUCTION CAMPAIGN MODULE
// ==========================================
model AuctionItem {
  id            Int           @id @default(autoincrement())
  assetId       Int
  asset         Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  reservePrice  Decimal       @db.Decimal(14, 2) 
  startingBid   Decimal       @db.Decimal(14, 2)
  depositAmount Decimal       @db.Decimal(12, 2) 
  
  startTime     DateTime      @default(now())
  endTime       DateTime      
  status        String        @default("UPCOMING") // UPCOMING, ACTIVE, CLOSED, SUSPENDED

  // WebRTC Multimedia Connectors
  liveRoomId    String?       @unique @db.VarChar(100) 

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  bids          Bid[]
  images        AssetImage[]
  registrations AuctionRegistration[]

  @@map("auction_items")
}

// Auxiliary table for handling multiple display photos per auction lot
model AssetImage {
  id            Int         @id @default(autoincrement())
  url           String      @db.Text
  isPrimary     Boolean     @default(false)
  auctionItemId Int
  auctionItem   AuctionItem @relation(fields: [auctionItemId], references: [id], onDelete: Cascade)

  @@map("asset_images")
}

// ==========================================
// 4. AUCTION BIDDER REGISTRATION
// ==========================================
model AuctionRegistration {
  id            Int                @id @default(autoincrement())
  userId        Int
  user          User               @relation(fields: [userId], references: [id])
  auctionItemId Int
  auctionItem   AuctionItem        @relation(fields: [auctionItemId], references: [id])
  status        String             @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt     DateTime           @default(now())

  @@unique([userId, auctionItemId]) 
  @@map("auction_registrations")
}

// ==========================================
// 5. LIVE TRANSACTIONAL BIDDING MODULE
// ==========================================
model Bid {
  id            Int         @id @default(autoincrement())
  amount        Decimal     @db.Decimal(14, 2)
  createdAt     DateTime    @default(now())
  isWinningBid  Boolean     @default(false) 

  bidderId      Int
  bidder        User        @relation(fields: [bidderId], references: [id])
  
  auctionItemId Int
  auctionItem   AuctionItem @relation(fields: [auctionItemId], references: [id], onDelete: Cascade)

  @@index([auctionItemId, amount(sort: Desc)]) 
  @@map("bids")
}

// ==========================================
// 6. FINANCIAL PAYMENTS GATEWAY LOGS
// ==========================================
model Payment {
  id            Int            @id @default(autoincrement())
  userId        Int
  user          User           @relation(fields: [userId], references: [id])
  amount        Decimal        @db.Decimal(14, 2)
  reference     String         @unique 
  gatewayStatus String         
  purpose       String         // REGISTRATION_DEPOSIT, FINAL_PROPERTY_PAYMENT
  createdAt     DateTime       @default(now())

  @@map("payments")
}