{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
, "app/actions/liveAuction.js", "app/auctions/live/[roomId]/page.jsx", "app/dashboard/page.jsx", "app/api/auth/[...nextauth]/route.js", "app/api/register/route.js", "app/(auth)/login/page.jsx", "app/(auth)/signup/page.jsx", "components/dashboard/AuctioneerDashboard.jsx", "components/dashboard/BidderDashboard.jsx", "auth.js"  ],
  "exclude": ["node_modules"]
}
